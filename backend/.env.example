# ── Server ─────────────────────────────────────────────
PORT=8080
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ── Database ───────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/sharda_helpdesk

# ── Auth ───────────────────────────────────────────────
JWT_SECRET=change_this_to_a_very_long_random_string_in_production
JWT_EXPIRE=7d
INITIAL_ADMIN_NAME=System Administrator
INITIAL_ADMIN_EMAIL=admin@university.edu
INITIAL_ADMIN_PASSWORD=change_this_admin_password
INITIAL_ADMIN_DEPARTMENT=Administration
INITIAL_ADMIN_EXPIRY_DATE=
ALLOWED_EMAIL_DOMAINS=sharda.ac.in,student.sharda.ac.in,faculty.sharda.ac.in

# ── Redis (Phase 3: Caching + Phase 4: Job Queue) ──────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Email (Phase 4: Async via Resend) ──────────────────
RESEND_API_KEY=re_your_api_key_here
FROM_EMAIL=onboarding@resend.dev
