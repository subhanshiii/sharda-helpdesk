# ── Server ─────────────────────────────────────────────
PORT=8080
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ── Database ───────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/sharda_helpdesk

# ── Auth ───────────────────────────────────────────────
JWT_SECRET=change_this_to_a_very_long_random_string_in_production
JWT_EXPIRE=7d
INITIAL_ADMIN_NAME=System Administrator
INITIAL_ADMIN_EMAIL=admin@university.edu
INITIAL_ADMIN_PASSWORD=change_this_admin_password
INITIAL_ADMIN_DEPARTMENT=Administration
INITIAL_ADMIN_EXPIRY_DATE=
ALLOWED_EMAIL_DOMAINS=sharda.ac.in,student.sharda.ac.in,faculty.sharda.ac.in

# ── Redis (caching, chat, Bull email job queue) ─────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Email (SMTP — outbound mail; configure EMAIL_USER/EMAIL_PASS) ─
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_16_char_app_password
FROM_EMAIL=your_email@gmail.com

# ── Google Sign-In ─────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
